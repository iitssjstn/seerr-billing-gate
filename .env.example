# Niets hier is verplicht om te starten! De app genereert bij de eerste
# start zelf een sessiegeheim en bewaart die in de database. Je admin-
# account maak je aan via de app zelf (/setup, bij het eerste bezoek).
# Seerr's URL/API-key en de betalingsopties stel je ook in de app in
# (Instellingen, na inloggen).

# Optioneel: poort waarop de app binnen de container draait
# (compose mapt 3010 -> deze poort)
# PORT=3000

# Optioneel: zet dit alleen als je zelf een vast sessiegeheim wilt
# afdwingen in plaats van het automatisch gegenereerde. Niet nodig voor
# normaal gebruik.
# SESSION_SECRET=

# Alleen relevant als je een oudere versie van deze app gebruikte: als je
# hier nog een ADMIN_PASSWORD_HASH had staan, wordt die bij de eerste start
# automatisch omgezet naar een account met gebruikersnaam "admin".
# ADMIN_PASSWORD_HASH=

# Optioneel: startwaarden voor Seerr-koppeling/betalingsopties, gelden
# totdat je ze via Instellingen in de app wijzigt.
# SEERR_URL=
# SEERR_API_KEY=
# PAYMENT_PERIOD_DAYS=30
# AUTO_REVOKE=false
